local WearModelCache = {}

local function ScanWorkspaceForWear(modelHandle)
    
    if WearModelCache[modelHandle] then return WearModelCache[modelHandle] end
    
    local petsFolder = workspace:FindFirstChild("Pets")
    if not petsFolder then return nil end
    for _, pet in ipairs(petsFolder:GetChildren()) do
        local pm = pet:FindFirstChild("PetModel")
        if pm then
            for _, child in ipairs(pm:GetChildren()) do
                if child.Name == modelHandle then
                    local ok, clone = pcall(function() return child:Clone() end)
                    if ok and clone then
                        WearModelCache[modelHandle] = clone
                        return clone
                    end
                end
            end
        end
    end
    return nil
end

local function ApplyPetWear(petUniqueId, wearId)
    if not wearId or not PetAvatarItemDB then return end
    local wearData = PetAvatarItemDB.items_by_kind and PetAvatarItemDB.items_by_kind[wearId]
    if not wearData then
        ShowNotif("Pet Wear", "Unknown wear ID: " .. tostring(wearId), "warn")
        return
    end

    local pet = SpawnedPets[petUniqueId]
    if not pet or not pet.model then
        ShowNotif("Pet Wear", "Pet model not found!", "warn")
        return
    end

    
    local petTopModel = pet.model
    local pm = petTopModel:FindFirstChild("PetModel") or petTopModel

    task.spawn(function()
        local accessoryAsset = nil

        
        local ok1, direct = pcall(function()
            local folder = RS:FindFirstChild("Downloadable") and RS.Downloadable:FindFirstChild("PetAvatarResources")
            return folder and folder:FindFirstChild(wearData.model_handle)
        end)
        if ok1 and direct then
            accessoryAsset = direct:Clone()
        end

        
        if not accessoryAsset then
            local ok2, downloaded = pcall(function()
                return DownloadClient.promise_download_copy("PetAvatarResources", wearData.model_handle):expect()
            end)
            if ok2 and downloaded then
                accessoryAsset = downloaded:Clone()
            end
        end

        
        if not accessoryAsset then
            local wearModel = ScanWorkspaceForWear(wearData.model_handle)
            if wearModel then
                accessoryAsset = wearModel:Clone()
            end
        end

        if not accessoryAsset then
            ShowNotif("Pet Wear", "Could not load: " .. (wearData.name or wearId), "warn")
            return
        end

        
        accessoryAsset.Parent = pm

        
        if PetAccessoryHelper and PetAccessoryHelper.equip_accessory then
            local equipOk, equipErr = pcall(function()
                PetAccessoryHelper.equip_accessory({
                    pet_model            = pm,
                    accessory_base_asset = accessoryAsset,
                    accessory_item_entry = wearData,
                    play_poof_effect     = false,
                    is_mannequin         = false,
                })
            end)
            if equipOk then
                ShowNotif("Pet Wear", (wearData.name or wearId) .. " equipped!", "success")
                return
            end
            warn("[PetWear] equip_accessory failed: " .. tostring(equipErr))
        end

        
        local attachName = wearTypeToAttachment[wearData.accessory_type or wearData.equip_type]
        local targetAttach = nil
        if attachName then
            for _, v in ipairs(pm:GetDescendants()) do
                if v:IsA("Attachment") and v.Name == attachName then
                    targetAttach = v
                    break
                end
            end
        end
        
        if not targetAttach then
            for _, v in ipairs(pm:GetDescendants()) do
                if v:IsA("Attachment") then
                    targetAttach = v
                    break
                end
            end
        end

        if not targetAttach then
            ShowNotif("Pet Wear", "No attachment point on pet for: " .. (wearData.name or wearId), "warn")
            return
        end

        
        local accessoryPart = nil
        if accessoryAsset:IsA("BasePart") then
            accessoryPart = accessoryAsset
        else
            accessoryPart = accessoryAsset.PrimaryPart
                or accessoryAsset:FindFirstChildOfClass("BasePart")
        end

        if not accessoryPart then
            ShowNotif("Pet Wear", "Accessory has no BasePart: " .. (wearData.name or wearId), "warn")
            return
        end

        
        for _, p in ipairs(accessoryAsset:GetDescendants()) do
            if p:IsA("BasePart") then
                p.Anchored = false
                p.CanCollide = false
            end
        end

        
        local weld = Instance.new("WeldConstraint")
        weld.Part0 = accessoryPart
        weld.Part1 = targetAttach.Parent
        weld.Parent = accessoryPart

        
        accessoryPart.CFrame = targetAttach.WorldCFrame

        ShowNotif("Pet Wear", (wearData.name or wearId) .. " equipped! (manual weld)", "success")
    end)
end

