CreateButton(SpawnTab.Frame, "👗 DRESS UP PET", Color3.fromRGB(180, 80, 180), 7, function()
    if not EquippedPet then
        ShowNotif("Dress Up", "No pet equipped! Spawn one first.", "warn")
        return
    end
    local wrappers = ClientData.get("pet_char_wrappers")
    if not wrappers then return end
    local petWrapper = nil
    for _, w in ipairs(wrappers) do
        if w.pet_unique == EquippedPet.unique then
            petWrapper = w
            break
        end
    end
    if not petWrapper then
        ShowNotif("Dress Up", "Pet wrapper not found.", "warn")
        return
    end
    local FocusPetApp = UIManager.apps.FocusPetApp
    if FocusPetApp then
        local ok, err = pcall(function()
            FocusPetApp:show({
                pet_unique = petWrapper.pet_unique,
                player = Players.LocalPlayer,
            })
        end)
        if not ok then
            ShowNotif("Dress Up", "Failed: " .. tostring(err), "warn")
        end
    end
end)

