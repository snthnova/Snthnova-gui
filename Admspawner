    TabFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    TabFrame.ScrollingDirection = Enum.ScrollingDirection.Y
    TabFrame.ElasticBehavior = Enum.ElasticBehavior.Never
    TabFrame.Visible = false
    TabFrame.ZIndex = 8
    TabFrame.VerticalScrollBarPosition = Enum.VerticalScrollBarPosition.Right

    local L = Instance.new("UIListLayout", TabFrame)
    L.SortOrder = Enum.SortOrder.LayoutOrder
    L.Padding = UDim.new(0, 6)
    local P = Instance.new("UIPadding", TabFrame)
    P.PaddingLeft = UDim.new(0, 10)
    P.PaddingRight = UDim.new(0, 14)
    P.PaddingTop = UDim.new(0, 10)
    P.PaddingBottom = UDim.new(0, 20)

    local tab = {Button = TabBtn, Frame = TabFrame, Bar = ActiveBar, Name = NameL}
    table.insert(Tabs, tab)

    local function Activate()
        for _, t in ipairs(Tabs) do
            t.Frame.Visible = false
            t.Bar.Visible = false
            TweenService:Create(t.Button, TweenInfo.new(0.15), {BackgroundTransparency = 1}):Play()
            TweenService:Create(t.Name, TweenInfo.new(0.15), {TextColor3 = C.TextMuted}):Play()
        end
        TabFrame.Visible = true
        ActiveBar.Visible = true
        TweenService:Create(TabBtn, TweenInfo.new(0.15), {BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(255, 255, 255)}):Play()
        TweenService:Create(NameL, TweenInfo.new(0.15), {TextColor3 = C.TextMain}):Play()
    end

    TabBtn.MouseButton1Click:Connect(Activate)
    TabBtn.MouseEnter:Connect(function()
        if ActiveBar.Visible then return end
        TweenService:Create(TabBtn, TweenInfo.new(0.12), {BackgroundTransparency = 0, BackgroundColor3 = Color3.fromRGB(250, 250, 250)}):Play()
        TweenService:Create(NameL, TweenInfo.new(0.12), {TextColor3 = C.TextSub}):Play()
    end)
    TabBtn.MouseLeave:Connect(function()
        if ActiveBar.Visible then return end
        TweenService:Create(TabBtn, TweenInfo.new(0.12), {BackgroundTransparency = 1}):Play()
        TweenService:Create(NameL, TweenInfo.new(0.12), {TextColor3 = C.TextMuted}):Play()
    end)

    if #Tabs == 1 then task.defer(Activate) end
    return tab
end

