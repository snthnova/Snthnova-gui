local function populateWear(filter)
    
    for _, b in ipairs(wearBtns) do b:Destroy() end
    wearBtns = {}
    if not PetAvatarItemDB or not PetAvatarItemDB.items_by_kind then return end
    local count = 0
    for id, data in pairs(PetAvatarItemDB.items_by_kind) do
        if count >= 20 then break end
        local name = data.name or id
        if filter == "" or name:lower():find(filter:lower()) or id:lower():find(filter:lower()) then
            local btn = Instance.new("TextButton", wearResultsFrame)
            btn.Size = UDim2.new(0.5, -3, 0, 22)
            btn.BackgroundColor3 = selectedWearIds[id] and C.AccentBtn or C.InputBG
            btn.BorderSizePixel = 0
            btn.Text = name
            btn.Font = Enum.Font.GothamSemibold
            btn.TextSize = 9
            btn.TextColor3 = selectedWearIds[id] and Color3.fromRGB(255,255,255) or C.TextSub
            btn.AutoButtonColor = false
            btn.ClipsDescendants = true
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            btn.MouseButton1Click:Connect(function()
                if selectedWearIds[id] then
                    
                    selectedWearIds[id] = nil
                    btn.BackgroundColor3 = C.InputBG
                    btn.TextColor3 = C.TextSub
                    ShowNotif("Wear Removed", name, "info")
                else
                    
                    selectedWearIds[id] = name
                    btn.BackgroundColor3 = C.AccentBtn
                    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
                    ShowNotif("Wear Added", name, "success")
                end
                UpdateWearTags()
            end)
            table.insert(wearBtns, btn)
            count = count + 1
        end
    end
end


