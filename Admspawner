local function CreateInventoryItem(itemId, category, properties)
    local uniqueId = GenerateUniqueID()
    local itemKindData = KindDB[itemId]

    if not itemKindData then
        warn("Item not found: " .. itemId)
        return nil
    end

    properties = properties or {}
    local newnessValue = NextToyOrder

    if category == "pets" then
        local groupKey = GetPropertyGroup(properties)
        NewnessGroups[groupKey] = NewnessGroups[groupKey] - 1
        newnessValue = NewnessGroups[groupKey]

        
        local safeProperties = {
            flyable = properties.flyable or false,
            rideable = properties.rideable or false,
            age = properties.age or math.random(1, 6),
            friendship_level = properties.friendship_level or 0,
            pet_trick_level = properties.pet_trick_level or 0,
            rp_name = properties.rp_name or GenerateUniquePetName()
        }
        
        if properties.neon then
            safeProperties.neon = true
        end
        if properties.mega_neon then
            safeProperties.mega_neon = true
        end
        
        if next(selectedWearIds) ~= nil then
            safeProperties.wearing = true
        end
        
        properties = safeProperties
    else
        NextToyOrder = NextToyOrder - 1
        newnessValue = NextToyOrder
    end

    local itemData = {
        unique = uniqueId,
        category = category,
        id = itemId,
        kind = itemKindData.kind,
        newness_order = newnessValue,
        properties = properties,
        _source = "blueprint.lua"
    }

    local identity = get_thread_identity and get_thread_identity() or 8
    set_thread_identity(2)
    
    local inventory = ClientData.get("inventory")
    if inventory then
        if not inventory[category] then
            inventory[category] = {}
        end
        inventory[category][uniqueId] = itemData
    else
        warn("Inventory not available yet, attempting to create...")
        ClientData.predict("inventory", { pets = {}, toys = {}, vehicles = {}, gifts = {}, food = {} })
        inventory = ClientData.get("inventory")
        if inventory then
            if not inventory[category] then
                inventory[category] = {}
            end
            inventory[category][uniqueId] = itemData
        end
    end
    
    set_thread_identity(identity)

    if category == "pets" then
        SpawnedPets[uniqueId] = { data = itemData, model = nil }
    end
    
    SpawnedItems[uniqueId] = true

    task.defer(function()
        if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
            pcall(function()
                UIManager.apps.BackpackApp:refresh_rendered_items()
            end)
        end
    end)

    return itemData
end

local function DeleteAllSpawnedPets()
    local identity = get_thread_identity and get_thread_identity() or 8
    set_thread_identity(2)
    
    local inventory = ClientData.get("inventory")
    local removed = 0
    
    if inventory and inventory.pets then
        for uniqueId, _ in pairs(SpawnedItems) do
            if inventory.pets[uniqueId] and inventory.pets[uniqueId]._source == "blueprint.lua" then
                inventory.pets[uniqueId] = nil
                removed = removed + 1
            end
        end
    end
    
    set_thread_identity(identity)
    
    for uniqueId, _ in pairs(SpawnedPets) do
        if SpawnedPets[uniqueId] and SpawnedPets[uniqueId].data and SpawnedPets[uniqueId].data._source == "blueprint.lua" then
            if SpawnedPets[uniqueId].model then
                pcall(function()
                    SpawnedPets[uniqueId].model:Destroy()
                end)
            end
            PetAilmentsCache[uniqueId] = nil  
        end
    end
    
    SpawnedPets = {}
    SpawnedItems = {}
    PetAilmentsCache = {}
    EquippedPet = nil
    CurrentRideId = nil
    
    task.defer(function()
        if UIManager and UIManager.apps and UIManager.apps.BackpackApp then
            pcall(function()
                UIManager.apps.BackpackApp:refresh_rendered_items()
            end)
        end
    end)
    
    return removed
end

local function FindPetId(petName)
    if not InventoryDB or not InventoryDB.pets then return nil end
    for id, info in pairs(InventoryDB.pets) do
        if info and info.name and info.name:lower() == petName:lower() then
            return id
        end
    end
    return nil
end

local function FindToyId(toyName)
    if not InventoryDB or not InventoryDB.toys then return nil end
    for id, info in pairs(InventoryDB.toys) do
        if info and info.name and info.name:lower() == toyName:lower() then
            return id
        end
    end
    return nil
end

local function FindItemId(itemName)
    local categories = {
        {name = "pets", finder = FindPetId},
        {name = "toys", finder = FindToyId}
    }
    
    for _, cat in ipairs(categories) do
        local id = cat.finder(itemName)
        if id then return id, cat.name end
    end
    return nil, nil
end

local OriginalRouterGet = RouterClient.get


local SpawnedToys = {}

function RouterClient.get(endpoint)
    if endpoint == "ToolAPI/Equip" then
        return {
            InvokeServer = function(_, uniqueId)
                
                local pet = SpawnedPets[uniqueId]
                if pet then
                    EquipPet(pet.data)
                    return true, { action = "equip", is_server = true }
                end
                
                if SpawnedToys[uniqueId] then
                    local toyData = SpawnedToys[uniqueId]
                    task.spawn(function()
                        local ok, ItemModelHelper = pcall(function()
                            return require(RS.ClientModules.Game.ItemModelHelper)
                        end)
                        if not ok or not ItemModelHelper then
                            warn("[ToySpawner] Failed to load ItemModelHelper: " .. tostring(ItemModelHelper))
                            return
                        end

                        warn("[ToySpawner] Downloading model for id: " .. tostring(toyData.id))

                        local resolveOk, model = pcall(function()
                            return ItemModelHelper.promise_download_item_model(toyData.id):expect()
                        end)

                        if not resolveOk or not model then
                            warn("[ToySpawner] ItemModelHelper download failed: " .. tostring(model))
                            return
                        end

                        warn("[ToySpawner] Got model: " .. model.Name .. " ClassName: " .. model.ClassName)

                        local char = LocalPlayer.Character
                        if not char then return end

                        local rightHand = char:FindFirstChild("RightHand")
                            or char:FindFirstChild("Right Arm")
                        if not rightHand then
                            warn("[ToySpawner] No right hand found")
                            return
                        end

                        
                        
                        local mountPart = model:FindFirstChild("RightMount", true)
                            or model:FindFirstChild("LeftMount", true)
                            or model:FindFirstChild("RootMount", true)

                        
                        if not mountPart then
                            mountPart = model.PrimaryPart
                        end
                        if not mountPart then
                            for _, part in ipairs(model:GetDescendants()) do
                                if part:IsA("BasePart") then
                                    mountPart = part
                                    break
                                end
                            end
                        end
                        if model:IsA("BasePart") then
                            mountPart = model
                        end

                        if not mountPart then
                            warn("[ToySpawner] No BasePart found in model")
                            return
                        end

                        warn("[ToySpawner] Welding to part: " .. mountPart.Name)

                        
                        local partCount = 0
                        for _, part in ipairs(model:GetDescendants()) do
                            if part:IsA("BasePart") then
                                part.Anchored = false
                                part.CanCollide = false
                                part.Massless = true
                                partCount = partCount + 1
                                warn("[ToySpawner] Part: " .. part.Name .. " T:" .. part.Transparency .. " Anchored was reset")
                            end
                        end
                        if model:IsA("BasePart") then
                            model.Anchored = false
                            model.CanCollide = false
                            model.Massless = true
                        end
                        warn("[ToySpawner] Total parts: " .. partCount)

                        
                        model.Parent = char

                        
                        
                        for _, part in ipairs(model:GetDescendants()) do
                            if part:IsA("BasePart") and part ~= mountPart then
                                local internalWeld = Instance.new("WeldConstraint")
                                internalWeld.Part0 = mountPart
                                internalWeld.Part1 = part
                                internalWeld.Parent = mountPart
                            end
                        end

                        
                        local toyOffsets = {
                            ["winter_2022_rainbow_rattle"] = CFrame.new(0, -0.3, 0) * CFrame.Angles(0, 0, math.rad(90)),
                        }

                        local offsetCF = toyOffsets[toyData.id] or CFrame.new(0, 0, -0.3)

                        
                        local weld = Instance.new("Motor6D")
                        weld.Name = "ToyWeld"
                        weld.Part0 = rightHand
                        weld.Part1 = mountPart
                        weld.C0 = offsetCF
                        weld.C1 = CFrame.new(0, 0, 0)
                        weld.Parent = rightHand

                        SpawnedToys[toyData.unique].weld = weld
                        SpawnedToys[toyData.unique].model = model

                        warn("[ToySpawner] Done! Model parented to character and welded.")
                    end)
                    return true, { action = "equip", is_server = true }
                end
                return OriginalRouterGet("ToolAPI/Equip"):InvokeServer(uniqueId)
            end
        }
    elseif endpoint == "ToolAPI/Unequip" then
        return {
            InvokeServer = function(_, uniqueId)
                local pet = SpawnedPets[uniqueId]
                if pet then
                    UnequipPet(pet.data)
                    return true, { action = "unequip", is_server = true }
                end
                if SpawnedToys[uniqueId] then
                    local toyData = SpawnedToys[uniqueId]
                    if toyData.weld then
                        pcall(function() toyData.weld:Destroy() end)
                        toyData.weld = nil
                    end
                    if toyData.model then
                        pcall(function() toyData.model:Destroy() end)
                        toyData.model = nil
                    end
                    return true, { action = "unequip", is_server = true }
                end
                return OriginalRouterGet("ToolAPI/Unequip"):InvokeServer(uniqueId)
            end
        }
    elseif endpoint == "AdoptAPI/RidePet" then
        return {
            InvokeServer = function(_, petData)
                local pet = SpawnedPets[petData.pet_unique]
                if not pet then
                    return OriginalRouterGet("AdoptAPI/RidePet"):InvokeServer(petData)
                end
                RidePet(petData.pet_unique)
                return true
            end
        }
    elseif endpoint == "AdoptAPI/FlyPet" then
        return {
            InvokeServer = function(_, petData)
                local pet = SpawnedPets[petData.pet_unique]
                if not pet then
                    return OriginalRouterGet("AdoptAPI/FlyPet"):InvokeServer(petData)
                end
                FlyPet(petData.pet_unique)
                return true
            end
        }
    elseif endpoint == "AdoptAPI/ExitSeatStates" then
        return {
            FireServer = function()
                if CurrentRideId then
                    DismountPet()
                    return true
                end
                return OriginalRouterGet("AdoptAPI/ExitSeatStates"):FireServer()
            end
        }
    elseif endpoint == "SettingsAPI/SetPetRoleplayName" then
        return {
            InvokeServer = function(_, petUniqueId, newName)
                local pet = SpawnedPets[petUniqueId]
                if not pet then
                    return OriginalRouterGet("SettingsAPI/SetPetRoleplayName"):InvokeServer(petUniqueId, newName)
                end
                
                local identity = get_thread_identity and get_thread_identity() or 8
                set_thread_identity(2)
                
                local inventory = ClientData.get("inventory")
                if inventory and inventory.pets and inventory.pets[petUniqueId] then
                    inventory.pets[petUniqueId].properties.rp_name = newName
                end
                
                if pet.data then
                    pet.data.properties.rp_name = newName
                end
                
                local wrappers = ClientData.get("pet_char_wrappers")
                if wrappers then
                    for _, wrapper in pairs(wrappers) do
                        if wrapper and wrapper.pet_unique == petUniqueId then
                            wrapper.rp_name = newName
                            break
                        end
                    end
                end
                
                set_thread_identity(identity)
                return true
            end
        }
    elseif endpoint == "ToolAPI/EquipPetAccessory" or endpoint == "PetAccessoryAPI/Equip" or endpoint == "ToolAPI/EquipAccessory" then
        return {
            InvokeServer = function(_, wearUniqueId, petUniqueId)
                
                local pet = SpawnedPets[petUniqueId]
                if not pet or not pet.model then return false end
                if not PetAvatarItemDB then return false end

                
                local identity = getthreadidentity and getthreadidentity() or 8
                setthreadidentity(2)
                local inventory = ClientData.get("inventory")
                setthreadidentity(identity)

                local wearItem = inventory and inventory.pet_accessories and inventory.pet_accessories[wearUniqueId]
                if not wearItem then return false end

                local wearData = PetAvatarItemDB.items_by_kind and PetAvatarItemDB.items_by_kind[wearItem.id]
                if not wearData then return false end

                
                if PetAccessoryHelper then
                    local attachName = wearTypeToAttachment[wearData.accessory_type]
                    local pm = pet.model:FindFirstChild("PetModel")
                    if pm and attachName then
                        local targetAttachment = nil
                        for _, v in ipairs(pm:GetDescendants()) do
                            if v:IsA("Attachment") and v.Name == attachName then
                                targetAttachment = v
                                break
                            end
                        end
                        if targetAttachment then
                            
                            local wearClone = nil
                            local petsFolder = workspace:FindFirstChild("Pets")
                            if petsFolder then
                                for _, otherPet in ipairs(petsFolder:GetChildren()) do
                                    local opm = otherPet:FindFirstChild("PetModel")
                                    if opm then
                                        for _, child in ipairs(opm:GetChildren()) do
                                            if child.Name == wearData.model_handle or child.Name == wearData.name then
                                                local ok, clone = pcall(function() return child:Clone() end)
                                                if ok and clone then wearClone = clone break end
                                            end
                                        end
                                    end
                                    if wearClone then break end
                                end
                            end
                            if wearClone then
                                wearClone.Parent = pet.model
                                local wearPart = wearClone:FindFirstChildOfClass("BasePart") or wearClone
                                if wearPart and wearPart:IsA("BasePart") then
                                    pcall(PetAccessoryHelper.attach_part_by_attachment, wearPart, targetAttachment)
                                end
                                return true
                            end
                        end
                    end
                end
                return false
            end
        }
    else
        return OriginalRouterGet(endpoint)
    end
end


