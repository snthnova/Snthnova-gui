local function WaitForInventory()
    local maxAttempts = 50
    local attempts = 0
    local inventory = nil
    
    while attempts < maxAttempts do
        inventory = ClientData.get("inventory")
        if inventory then
            break
        end
        task.wait(0.1)
        attempts = attempts + 1
    end
    
    return inventory
end

local function GenerateUniquePetName()
    local prefixes = {"★", "☆", "♡", "☁️", "✨", "🍓", "🌸", "🍯", "☕", "🌙", "🌈", "❄️", "🫧", "🍬", "🍪", "🥛"}
